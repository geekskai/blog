{
  "compilerOptions": {
    "incremental": true,
    "target": "ES6",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["components/*"],
      "@/data/*": ["data/*"],
      "@/layouts/*": ["layouts/*"],
      "@/utils/*": ["utils/*"],
      "@/css/*": ["css/*"],
      "@/app/*": ["app/*"],
      "contentlayer/generated": ["./.contentlayer/generated"],
      "pliny/analytics": ["./node_modules/pliny/analytics/index.js"],
      "pliny/search": ["./node_modules/pliny/search/index.js"],
      "soundcloud-downloader": ["./types/soundcloud-downloader"],
      "soundcloud-downloader/dist/info": ["./types/soundcloud-downloader"],
      "soundcloud-downloader/dist/download": ["./types/soundcloud-downloader"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "global.d.ts",
    "types/**/*.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/i18n/**/*.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "layouts/**/*.ts",
    "layouts/**/*.tsx",
    "utils/**/*.ts",
    "utils/**/*.tsx",
    "utils/**/*.js",
    "data/**/*.ts",
    "scripts/**/*.js",
    "scripts/**/*.mjs",
    "contentlayer.config.ts",
    ".contentlayer/generated",
    ".contentlayer/generated/**/*.json",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
